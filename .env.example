# Cockroach async SQLAlchemy URL
COCKROACH_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:26257/DB_NAME?sslmode=require

# Single Sorsa API key
SORSA_API_KEY=YOUR_API_KEY

# Optional tuning
SORSA_BASE_URL=https://api.sorsa.io/v3
SORSA_PER_KEY_RPS=20
SEARCH_SLICE_COUNT=20
SEARCH_MAX_CONCURRENCY=20
SEARCH_ORDER=latest
SORSA_MAX_RETRIES=4
SORSA_RETRY_429_SLEEP_SECONDS=1.0
SORSA_RETRY_5XX_SLEEP_SECONDS=2.0
