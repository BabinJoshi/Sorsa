# CockroachDB connection URL (plain postgresql:// — no +asyncpg driver tag needed)
COCKROACH_DATABASE_URL=postgresql://USER:PASSWORD@HOST:26257/DB_NAME?sslmode=require

# One or more Sorsa API keys (comma-separated). Add more keys for higher throughput.
# Each key independently supports SORSA_PER_KEY_RPS requests/sec.
# Example with 2 keys: SORSA_API_KEYS=key_aaa,key_bbb
SORSA_API_KEYS=YOUR_API_KEY

# Optional tuning — all of these have sensible defaults, only set if you need to override
SORSA_BASE_URL=https://api.sorsa.io/v3
SORSA_PER_KEY_RPS=20
SEARCH_SLICE_COUNT=20
SEARCH_ORDER=latest
SORSA_MAX_RETRIES=4
SORSA_RETRY_429_SLEEP_SECONDS=1.0
SORSA_RETRY_5XX_SLEEP_SECONDS=2.0
DB_WRITE_BATCH_SIZE=1000
# SEARCH_MAX_CONCURRENCY and AUX_MAX_CONCURRENCY are AUTO-COMPUTED as:
#   len(SORSA_API_KEYS) * SORSA_PER_KEY_RPS
# Only set these if you want to override the auto-computed value.
# SEARCH_MAX_CONCURRENCY=40
# AUX_MAX_CONCURRENCY=40
